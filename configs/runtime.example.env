# Kafka-Duplex runtime defaults for the optional real CosyVoice adapter.
# Copy to a local `.env` or export these variables directly before GPU validation.

KAFKA_DUPLEX_COSYVOICE_REPO_DIR=/root/CosyVoice
KAFKA_DUPLEX_COSYVOICE_MODEL_DIR=/root/CosyVoice/pretrained_models/CosyVoice-300M
KAFKA_DUPLEX_COSYVOICE_SAMPLE_RATE=16000
KAFKA_DUPLEX_COSYVOICE_LOAD_JIT=0
KAFKA_DUPLEX_COSYVOICE_LOAD_TRT=0
KAFKA_DUPLEX_COSYVOICE_LOAD_VLLM=0
KAFKA_DUPLEX_COSYVOICE_FP16=0
